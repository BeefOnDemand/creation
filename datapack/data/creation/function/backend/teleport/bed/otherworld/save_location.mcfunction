$data modify storage creation:player/$(uuid) player.bed.otherworld.dimension set from entity @s Dimension

$data modify storage creation:player/$(uuid) player.bed.otherworld.x set from block ~ ~ ~ x
$data modify storage creation:player/$(uuid) player.bed.otherworld.y_bed set from block ~ ~ ~ y
$data modify storage creation:player/$(uuid) player.bed.otherworld.y set from entity @s Pos[1]
$data modify storage creation:player/$(uuid) player.bed.otherworld.z set from block ~ ~ ~ z